# Secrets — never committed. The real env file lives outside the repo
# (~/.config/orchestrator/env, chmod 600 — scaffold with `orc init`).
.env
.env.*
!.env.example

# Instance config — a real routing-hints.json at the checkout root is a dev-run
# convenience (ORCHESTRATOR_ROUTING_HINTS_PATH); the repo ships only the example.
routing-hints.json

# Dev-instance state (ADR 0003) — the databases the dev loops write:
# dev:all's daemon db and the seeded demo db (`npm run seed:demo`).
.dev/

node_modules/

# Build output — emitted by `npm run build` (tsconfig.build.json), shipped in the npm tarball only.
dist/
