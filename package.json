{
  "name": "@nvergez/orchestrator",
  "version": "0.1.0",
  "description": "Slack-driven orchestrator-dispatcher daemon: one Claude Code session per Slack thread, delegating work to Orca worktree agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "orc": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "workspaces": [
    "web"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvergez/orchestrator.git"
  },
  "homepage": "https://github.com/nvergez/orchestrator#readme",
  "bugs": "https://github.com/nvergez/orchestrator/issues",
  "keywords": [
    "slack",
    "claude",
    "claude-code",
    "agent",
    "orchestrator",
    "orca",
    "daemon"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.ts",
    "dev": "node --env-file=.env src/index.ts",
    "dev:web": "npm run dev --workspace web",
    "seed:demo": "node src/dashboard/seed-demo.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:web": "npm run build --workspace web",
    "prepack": "npm run build && npm run build:web",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm run typecheck --workspace web",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.204",
    "@slack/bolt": "^4.7.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
