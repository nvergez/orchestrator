# Slack ↔ Orca orchestrator — secrets (template, WITHOUT values).
#
# Real values live outside the repo (e.g. ~/.config/orchestrator/env, chmod 600).
# NEVER commit the real .env or paste these values into an issue.
# Provisioned in ticket #2 "Provision the Slack app (Socket Mode)…".

# Bot User OAuth Token — starts with xoxb-  (OAuth & Permissions, after install)
SLACK_BOT_TOKEN=

# App-Level Token — starts with xapp-  (Socket Mode, connections:write scope)
SLACK_APP_TOKEN=

# ID of the dedicated #orchestrator channel — starts with C
SLACK_CHANNEL_ID=

# Authorized Slack user ID (single-user allow-list) — starts with U
SLACK_ALLOWED_USER_ID=

# Claude Code OAuth token — starts with sk-ant-  (run `claude setup-token`;
# subscription-billed daemon auth per spec §10, never --bare)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: pino log level (default: info)
#LOG_LEVEL=info

# Optional: SQLite override (default: $XDG_STATE_HOME else
# ~/.local/state, then orchestrator/orchestrator.db under it)
#ORCHESTRATOR_DB_PATH=

# Optional: routing-hints override (default: $XDG_CONFIG_HOME else ~/.config,
# then orchestrator/routing-hints.json under it — scaffold with `orc init`).
# Dev runs typically point this at a local, git-ignored copy of
# routing-hints.example.json:
#ORCHESTRATOR_ROUTING_HINTS_PATH=./routing-hints.json

# Optional: minutes a finished-turn session keeps its live process (default: 30)
#SESSION_WARM_TTL_MINUTES=30

# Optional: ascending per-session USD totals that each post one 💸 warning in
# the thread (spec §7 — measure-only, nothing ever blocks; default: 5,10)
#COST_WARN_THRESHOLDS_USD=5,10

# Optional: global cap on live sessions — dormant ones don't count (spec §3;
# at the cap the coldest finished-turn session is reaped, else ⏳ queue; default: 5)
#SESSION_LIVE_CAP=5

# Optional: global cap on concurrent Orca workers (spec §5) — delegations
# beyond it wait their wave with a ⏳ line in the thread (default: 3)
#WORKER_CAP=3

# Optional: days of dormancy after which the sweep auto-closes a session
# (spec §3; default: 7)
#SESSION_AUTO_CLOSE_DAYS=7

# Optional: minutes between dormancy sweeps (default: 60)
#SESSION_SWEEP_INTERVAL_MINUTES=60
