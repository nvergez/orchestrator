# Orchestrateur Slack ↔ Orca — secrets (modèle, SANS valeurs).
#
# Emplacement réel sur le VPS : /home/dev/projects/orchestrator/.env (hors-repo, chmod 600).
# Ne JAMAIS commiter le vrai .env ni coller ces valeurs dans une issue.
# Provisionnés au ticket #2 « Provisionner l'app Slack (Socket Mode)… ».

# Bot User OAuth Token — commence par xoxb-  (OAuth & Permissions, après install)
SLACK_BOT_TOKEN=

# App-Level Token — commence par xapp-  (Socket Mode, scope connections:write)
SLACK_APP_TOKEN=

# ID du channel dédié #orchestrator — commence par C
SLACK_CHANNEL_ID=

# User ID Slack autorisé (allow-list mono-utilisateur) — commence par U
SLACK_ALLOWED_USER_ID=
