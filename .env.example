# Slack ↔ Orca orchestrator — secrets (template, WITHOUT values).
#
# Actual location on the VPS: /home/dev/projects/orchestrator/.env (outside the repo, chmod 600).
# NEVER commit the real .env or paste these values into an issue.
# Provisioned in ticket #2 "Provision the Slack app (Socket Mode)…".

# Bot User OAuth Token — starts with xoxb-  (OAuth & Permissions, after install)
SLACK_BOT_TOKEN=

# App-Level Token — starts with xapp-  (Socket Mode, connections:write scope)
SLACK_APP_TOKEN=

# ID of the dedicated #orchestrator channel — starts with C
SLACK_CHANNEL_ID=

# Authorized Slack user ID (single-user allow-list) — starts with U
SLACK_ALLOWED_USER_ID=

# Claude Code OAuth token — starts with sk-ant-  (run `claude setup-token`;
# subscription-billed daemon auth per spec §10, never --bare)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: pino log level (default: info)
#LOG_LEVEL=info

# Optional: SQLite override (default: ~/.local/state/orchestrator/orchestrator.db)
#ORCHESTRATOR_DB_PATH=

# Optional: minutes a finished-turn session keeps its live process (default: 30)
#SESSION_WARM_TTL_MINUTES=30

# Optional: ascending per-session USD totals that each post one 💸 warning in
# the thread (spec §7 — measure-only, nothing ever blocks; default: 5,10)
#COST_WARN_THRESHOLDS_USD=5,10
